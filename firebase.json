{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/index.html",
        "destination": "/",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/api/deleteUserAccount",
        "function": "deleteUserAccount",
        "region": "us-central1"
      },
      {
        "source": "/api/criarUsuarioAdmin",
        "function": "criarUsuarioAdmin",
        "region": "us-central1"
      },
      {
        "source": "/api/geminiChat",
        "function": "geminiChat",
        "region": "us-central1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
