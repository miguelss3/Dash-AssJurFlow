rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Sistema interno — qualquer usuário autenticado é um militar credenciado.
    // A autorização por papel (admin/assessor/chefe) é feita no frontend.
    
    // Regras para a coleção de processos
    match /processos/{processoId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
      
      // Subcoleção de histórico
      match /historico/{mensagemId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Regras para a coleção de usuários
    match /usuarios/{userId} {
      allow read:  if request.auth != null;
      // Escrita restrita: apenas o admin universal por email
      allow write: if request.auth != null &&
                      request.auth.token.email == 'miguelss3@yahoo.com.br';
    }
    
    // Regras para a coleção de distribuições
    match /distribuicoes/{distribuicaoId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /mensagens/{mensagemId} {
      allow read, write: if request.auth != null;
    }
    
    // Regra padrão: negar acesso a outras coleções não especificadas
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
