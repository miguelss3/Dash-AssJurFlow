rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : '';
    }

    function isAdminUniversal() {
      return authEmail() == 'miguelss3@yahoo.com.br';
    }

    function hasUserProfileByUid() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function userProfileByUid() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function userSetor() {
      return hasUserProfileByUid() && userProfileByUid().setor != null
        ? userProfileByUid().setor
        : '';
    }

    function isChefePerfil() {
      return hasUserProfileByUid() && (
        userProfileByUid().isChefe == true ||
        userProfileByUid().isChefe == 'sim' ||
        userProfileByUid().isChefe == 'Sim' ||
        userProfileByUid().cargo == 'Admin Universal' ||
        userProfileByUid().setor == 'CHEFE ASSEAPASSJUR'
      );
    }

    function canManageSetor(setor) {
      return isAdminUniversal() ||
        isChefePerfil() ||
        (setor in ['DU', 'PA'] && userSetor() == setor);
    }

    function canReadProcessData(data) {
      return isSignedIn() && (
        isAdminUniversal() ||
        data.userId == request.auth.uid ||
        (data.setor in ['DU', 'PA'] && canManageSetor(data.setor))
      );
    }

    function processDocById(processoId) {
      return get(/databases/$(database)/documents/processos/$(processoId)).data;
    }

    function processExists(processoId) {
      return exists(/databases/$(database)/documents/processos/$(processoId));
    }

    function canAccessProcessById(processoId) {
      return isSignedIn() &&
        processExists(processoId) &&
        canReadProcessData(processDocById(processoId));
    }

    function isOwnerPayload(data) {
      return data.userId == request.auth.uid &&
        data.userEmail == authEmail();
    }

    function canCreateProcess(data) {
      return isSignedIn() &&
        (data.setor in ['DU', 'PA']) &&
        isOwnerPayload(data) &&
        canManageSetor(data.setor);
    }

    function canUpdateProcess(oldData, newData) {
      return isSignedIn() && (
        isAdminUniversal() ||
        (
          canManageSetor(oldData.setor) &&
          oldData.userId == newData.userId &&
          oldData.userEmail == newData.userEmail &&
          oldData.setor == newData.setor &&
          // Endurece update: bloqueia alteração de campos de identidade/origem.
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'userId',
            'userEmail',
            'setor',
            'criadoEm',
            'criadoPorUid',
            'criadoPorEmail'
          ])
        )
      );
    }

    function canDeleteProcess(oldData) {
      return isSignedIn() && canManageSetor(oldData.setor);
    }
    
    // Regras para a coleção de processos
    match /processos/{processoId} {
      allow get, list: if canReadProcessData(resource.data);
      allow create: if canCreateProcess(request.resource.data);
      allow update: if canUpdateProcess(resource.data, request.resource.data);
      allow delete: if canDeleteProcess(resource.data);
      
      // Subcoleção de histórico
      match /historico/{mensagemId} {
        allow read: if canAccessProcessById(processoId);
        allow create: if canAccessProcessById(processoId) &&
          request.resource.data.keys().hasOnly(['autor', 'autorId', 'texto', 'timestamp']) &&
          request.resource.data.autorId == request.auth.uid;
        allow update, delete: if false;
      }
    }
    
    // Regras para a coleção de usuários
    match /usuarios/{userId} {
      allow read:  if isSignedIn();
      // Escrita restrita: admin universal por email ou usuário com perfil de Chefe
      allow write: if isSignedIn() && (isAdminUniversal() || isChefePerfil());
    }
    
    // Regras para a coleção de distribuições
    match /distribuicoes/{distribuicaoId} {
      allow get, list: if resource.data.processoId is string &&
        canAccessProcessById(resource.data.processoId);
      allow create: if isSignedIn() &&
        request.resource.data.processoId is string &&
        canAccessProcessById(request.resource.data.processoId);
      allow update: if isSignedIn() &&
        resource.data.processoId is string &&
        request.resource.data.processoId == resource.data.processoId &&
        canAccessProcessById(resource.data.processoId);
      allow delete: if isAdminUniversal() || (
        isSignedIn() &&
        resource.data.processoId is string &&
        canAccessProcessById(resource.data.processoId)
      );
    }
    
    match /mensagens/{mensagemId} {
      allow read: if isAdminUniversal() || canAccessProcessById(mensagemId);
      allow create, update: if canAccessProcessById(mensagemId) &&
        request.resource.data.keys().hasOnly(['historico']);
      allow delete: if false;
    }

    match /eventosCalendario/{eventoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.setor in ['DU', 'PA'] &&
        canManageSetor(request.resource.data.setor) &&
        request.resource.data.data is string &&
        request.resource.data.titulo is string &&
        request.resource.data.tipo is string;
      allow update: if isSignedIn() &&
        resource.data.setor in ['DU', 'PA'] &&
        canManageSetor(resource.data.setor);
      allow delete: if isSignedIn() &&
        resource.data.setor in ['DU', 'PA'] &&
        canManageSetor(resource.data.setor);
    }

    match /configuracoesSistema/{configId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() &&
        isAdminUniversal() &&
        configId == 'layoutPrincipal' &&
        request.resource.data.keys().hasOnly([
          'sidebarTitle',
          'sidebarSubtitle',
          'dashboardTitle',
          'dashboardDescription',
          'newProcessLabel',
          'footerText',
          'prazoIPMInicialDias',
          'prazoIPMProrrogacaoDias',
          'prazoSindicanciaInicialDias',
          'prazoSindicanciaProrrogacaoDias',
          'prazoConselhoInicialDias',
          'prazoConselhoProrrogacaoDias',
          'assuntosPASindicancia',
          'assuntosDUPrincipais',
          'origensDUDocumentos',
          'paEmAndamentoColumns',
          'duBoardColumns',
          'columnTabs',
          'paFlowActions',
          'duFlowActions',
          'updatedAt',
          'updatedByName',
          'updatedByEmail'
        ]) &&
        request.resource.data.sidebarTitle is string &&
        request.resource.data.sidebarSubtitle is string &&
        request.resource.data.dashboardTitle is string &&
        request.resource.data.dashboardDescription is string &&
        request.resource.data.newProcessLabel is string &&
        request.resource.data.footerText is string &&
        request.resource.data.prazoIPMInicialDias is number &&
        request.resource.data.prazoIPMProrrogacaoDias is number &&
        request.resource.data.prazoSindicanciaInicialDias is number &&
        request.resource.data.prazoSindicanciaProrrogacaoDias is number &&
        request.resource.data.prazoConselhoInicialDias is number &&
        request.resource.data.prazoConselhoProrrogacaoDias is number &&
        request.resource.data.assuntosPASindicancia is list &&
        request.resource.data.assuntosDUPrincipais is list &&
        request.resource.data.origensDUDocumentos is list &&
        request.resource.data.paEmAndamentoColumns is list &&
        request.resource.data.duBoardColumns is list &&
        request.resource.data.columnTabs is list &&
        request.resource.data.paFlowActions is list &&
        request.resource.data.duFlowActions is list;
      allow delete: if false;
    }
    
    // Regra padrão: negar acesso a outras coleções não especificadas
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
